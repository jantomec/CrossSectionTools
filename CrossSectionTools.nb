 RowBox[{
  RowBox[{"torsionConstant", "[", "mesh_ElementMesh", "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Psi]", ",", "u", ",", "y", ",", "z"}], "}"}], ",", 
