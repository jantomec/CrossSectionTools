    RowBox[{
     RowBox[{"\[Psi]", "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"Laplacian", "[", 
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"y", ",", "z"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"y", ",", "z"}], "}"}]}], "]"}], "\[Equal]", 
           RowBox[{"-", "2"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"DirichletCondition", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"y", ",", "z"}], "]"}], "\[Equal]", "0"}], ",", 
            "True"}], "]"}]}], "\[IndentingNewLine]", "}"}], ",", "u", ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"y", ",", "z"}], "}"}], "\[Element]", "mesh"}]}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"2", 
      RowBox[{"NIntegrate", "[", 
       RowBox[{
        RowBox[{"\[Psi]", "[", 
         RowBox[{"y", ",", "z"}], "]"}], ",", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"y", ",", "z"}], "}"}], "\[Element]", "mesh"}]}], 
       "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], "Input",
