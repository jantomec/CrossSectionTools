Notebook[{
Cell[CellGroupData[{
Cell["CrossSectionTools \[LongDash] Examples", "Title"],

Cell["\<\
Load the paclet. If it is not installed yet, run
    PacletInstall[\"path/to/CrossSectionTools-1.0.0.paclet\"]
once. See README.md for install instructions.\
\>", "Text"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<CrossSectionTools`\>\"", "]"}]], "Input"],

Cell[CellGroupData[{
Cell["Example 1 \[LongDash] unit disk", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=",
   RowBox[{"Disk", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]",
 RowBox[{"CrossSection", "[", "\[CapitalOmega]", "]"}]}], "Input"]
}, Open]],

Cell[CellGroupData[{
Cell["Example 2 \[LongDash] union of a disk and a rectangle", "Section"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalOmega]2", "=",
   RowBox[{"RegionUnion", "[",
    RowBox[{
     RowBox[{"Disk", "[",
      RowBox[{
       RowBox[{"{",
        RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}], ",",
     RowBox[{"Rectangle", "[",
      RowBox[{
       RowBox[{"{",
        RowBox[{"0", ",", "0"}], "}"}], ",",
       RowBox[{"{",
        RowBox[{"1", ",", "1"}], "}"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]",
 RowBox[{"CrossSection", "[", "\[CapitalOmega]2", "]"}]}], "Input"]
}, Open]]
}, Open]]
}]
