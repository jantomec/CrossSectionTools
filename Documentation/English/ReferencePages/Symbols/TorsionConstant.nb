Notebook[{

Cell[CellGroupData[{
Cell["TorsionConstant", "ObjectName",ExpressionUUID->"1fa3d5d4-9280-4ace-ad00-b2687db59099"],

Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "56ec3ec6-1bfd-4ad2-8ecb-349c5b901d42"], Cell[BoxData[
     RowBox[{"TorsionConstant", "[", 
      StyleBox["mesh", "TI"], "]"}]], "Usage",ExpressionUUID->
     "40739e6a-ef9a-4adb-8b5d-b23d1210c880"], "\n", 
    RowBox[{
     RowBox[{"returns", " ", "the", " ", "Saint"}], "-", 
     RowBox[{
     "Venant", " ", "torsion", " ", "constant", " ", "J_t", " ", "of", " ", 
      "a", " ", "2", "D", " ", "cross"}], "-", 
     RowBox[{
     "section", " ", "given", " ", "as", " ", "a", " ", "MeshRegion", " ", 
      "or", " ", "an", " ", 
      RowBox[{"ElementMesh", "."}]}]}]}
  }]], "Usage",ExpressionUUID->"af0330e2-40b7-413b-894b-ce98d294b6da"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "NotesSection",ExpressionUUID->"b9e30ecd-2267-46b9-9a3a-837b046ff058"],

Cell["\<\
The torsion constant is computed by solving the Poisson problem 
    \[CapitalDelta] \[Psi] = -2 on the cross-section, \[Psi] = 0 on the \
boundary, 
and returning 2 \[Integral] \[Psi] dA.\
\>", "Notes",ExpressionUUID->"c2a71dfd-50fc-46d6-af0f-0034af3fa975"],

Cell["\<\
Accepts any MeshRegion (converted via ToElementMesh) or a prebuilt \
ElementMesh.\
\>", "Notes",ExpressionUUID->"f21868f9-2d16-43a8-a345-b8f1a92bc08b"],

Cell["\<\
The PDE is solved with NDSolveValue using the finite-element framework \
(NDSolve`FEM`).\
\>", "Notes",ExpressionUUID->"862c8ad3-aa4b-4442-87d0-afc0b1518e72"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "PrimaryExamplesSection",ExpressionUUID->"7b5d220a-72a4-4fe0-b055-8bb5afd91356"],

Cell[CellGroupData[{

Cell["Basic Examples", "ExampleSection",ExpressionUUID->"32901f95-c4d8-48a9-b042-292ad1d8f3af"],

Cell[BoxData[
 RowBox[{"Needs", "[", "\"\<CrossSectionTools`\>\"", "]"}]], "Input",Expressio\
nUUID->"619cdc4d-6742-4024-ae56-65de94061067"],

Cell["Torsion constant of a unit disk:", "ExampleText",ExpressionUUID->"6cec09be-05fa-4555-a0c1-ada8f81bf29b"],

Cell[BoxData[
 RowBox[{"TorsionConstant", "[",
  RowBox[{"DiscretizeRegion", "[",
   RowBox[{"Disk", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}], "]"}],
  "]"}]], "Input",ExpressionUUID->"72c4b57e-834c-47bf-b7a3-0f46c7d7053a"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100001"],

Cell["Torsion constant of a thin rectangle:", "ExampleText",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100002"],

Cell[BoxData[
 RowBox[{"TorsionConstant", "[",
  RowBox[{"DiscretizeRegion", "[",
   RowBox[{"Rectangle", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{"0", ",", "0"}], "}"}], ",",
     RowBox[{"{",
      RowBox[{"4", ",", "1"}], "}"}]}], "]"}], "]"}],
  "]"}]], "Input",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100003"],

Cell["\t", "ExampleDelimiter",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100004"],

Cell["Pass an ElementMesh built directly with ToElementMesh:", "ExampleText",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100005"],

Cell[BoxData[
 RowBox[{"TorsionConstant", "[",
  RowBox[{"NDSolve`FEM`ToElementMesh", "[",
   RowBox[{"Disk", "[",
    RowBox[{
     RowBox[{"{",
      RowBox[{"0", ",", "0"}], "}"}], ",", "1"}], "]"}], "]"}],
  "]"}]], "Input",ExpressionUUID->"7c4b57e0-1a11-4a13-9d1d-3f1a1c100006"]
}, Open  ]]
}, Open  ]]
},
