 RowBox[{"Needs", "[", "\"\<CrossSectionTools`\>\"", "]"}]], "Input",Expressio\
nUUID->"a52b98a4-5267-42ea-88dc-1861f006d9b7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Functions", "GuideFunctionsSection",ExpressionUUID->"2b67dc4e-4676-46f8-8bba-9f12b442b14d"],

Cell[TextData[{
 ButtonBox["CrossSection",
  BaseStyle->"Link",
  ButtonData->"paclet:CrossSectionTools/ref/CrossSection"],
 " \[LongDash] full summary of geometric and torsional properties with a plot."
}], "GuideText",ExpressionUUID->"160a7af0-8b62-46b7-9416-d4ea53b92074"],

Cell[TextData[{
 ButtonBox["TorsionConstant",
  BaseStyle->"Link",
