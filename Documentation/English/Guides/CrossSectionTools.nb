Notebook[{

Cell[CellGroupData[{
Cell["CrossSectionTools", "GuideTitle",ExpressionUUID->"fb8b48fc-a0e3-40da-ae3e-3cddb9869248"],

Cell["\<\
Tools for computing geometric and torsional properties of arbitrary 2D \
cross-sections in Wolfram Language. Given any 2D region, compute its area, \
centroid, moments of inertia, and Saint-Venant torsion constant.\
\>", "GuideAbstract",ExpressionUUID->"f69dfdcd-6276-4d79-857b-1eb3ff64d0d6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Loading", "GuideFunctionsSection",ExpressionUUID->"4b106bd2-e202-4636-8121-5e09a9fecc2d"],

